end

local function cframeInvalid(cf)
    if not cf then return true end
    local p = cf.Position
    if not p then return true end
    return p.Y < -10000 or math.abs(p.X) > 500000 or math.abs(p.Z) > 500000
end

local function generateDeepVoid()
    local positions = {}
    local depths = {-1e6, -2e6, -5e6, -1e7, -2e7}
    local far = {-1e6, -5e5, -2e5, -1e5, 1e5, 2e5, 5e5, 1e6}
    for i = 1, 20 do
        local x = far[math.random(1,#far)] + math.random(-5000,5000)
        local y = depths[math.random(1,#depths)] + math.random(-5000,5000)
        local z = far[math.random(1,#far)] + math.random(-5000,5000)
        positions[i] = CFrame.new(x,y,z)
    end
    return positions
end
local deepVoidPositions = generateDeepVoid()

local function updateSimulation(dt)
    if not framework.desyncEnabled then return end
    local S = framework.settings
    local baseVel = Vector3.new(
        math.random(-S.rand_vel_x, S.rand_vel_x),
        math.random(-S.rand_vel_y, S.rand_vel_y),
        math.random(-S.rand_vel_z, S.rand_vel_z)
    )
    local jerkIntensity = S.jerk_intensity / 100
    local randIntensity = S.random_vel_intensity / 100
    framework.jerkTimer -= dt
    if framework.jerkTimer <= 0 then
        framework.jerkTimer = math.random(3,10)/10
        local jerk = Vector3.new(
            math.random(-40,40) * jerkIntensity,
            math.random(-40,40) * jerkIntensity,
            math.random(-40,40) * jerkIntensity
        )
        framework.simVelocity = framework.simVelocity + jerk
    end
    local chaos = Vector3.new(
        math.random(-60,60) * randIntensity,
        math.random(-60,60) * randIntensity,
        math.random(-60,60) * randIntensity
    )
    framework.simVelocity = (framework.simVelocity * 0.9) + baseVel + chaos
    framework.simPosition = framework.simPosition + framework.simVelocity * dt
end

local function getDesyncOffset()
    local S = framework.settings
    local anchor = Vector3.new(0,0,0)
    if framework.voidActive and deepVoidPositions[framework.currentVoidIndex] then
        local baseCF = deepVoidPositions[framework.currentVoidIndex]
        local depth = S.depthMultiplier or 1
        local bp = baseCF.Position
        anchor = Vector3.new(bp.X * depth, bp.Y * depth, bp.Z * depth)
    end
    return anchor + framework.simPosition
end

local function startCSync()
    local char = LocalPlayer.Character
    local hrp = char and find(char,"HumanoidRootPart")
    if not hrp then return end
    if framework.csyncConnection then return end
    framework.csyncConnection = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        local hrp = char and find(char,"HumanoidRootPart")
        if not hrp then return end
        local realCF = hrp.CFrame
        local offset = getDesyncOffset()
        hrp.CFrame = CFrame.new(offset)
        RunService.RenderStepped:Wait()
        hrp.CFrame = realCF
    end)
end

local function stopCSync()
    if framework.csyncConnection then
        framework.csyncConnection:Disconnect()
        framework.csyncConnection = nil
    end
end

local function updateVoid(dt)
    if not framework.voidActive then return end
    local S = framework.settings
    if tick() - framework.lastSwitch < S.switchSpeed then return end
    framework.lastSwitch = tick()
    framework.currentVoidIndex = (framework.currentVoidIndex % #deepVoidPositions) + 1
end

local function startVoid()
    local char = LocalPlayer.Character
    local hrp = char and find(char,"HumanoidRootPart")
    if not hrp then return end
    framework.originalCFrame = hrp.CFrame
    framework.voidActive = true
    framework.desyncEnabled = true
    startCSync()
end

local function stopVoid()
    framework.voidActive = false
    framework.desyncEnabled = false
    stopCSync()
end

local function safeReturn()
    stopCSync()
    task.wait(0.1)
    local char = LocalPlayer.Character
    local hrp = char and find(char,"HumanoidRootPart")
    if not hrp then return end
    local returnCF = framework.originalCFrame or CFrame.new(0,20,0)
    if cframeInvalid(returnCF) then
        returnCF = CFrame.new(0,20,0)
    end
    hrp.CFrame = returnCF
end

