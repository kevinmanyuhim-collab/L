    }
}

local function cframeInvalid(cf)
    if not cf then return true end
    local p = cf.Position
    if not p then return true end
    return p.Y < -10000 or math.abs(p.X) > 500000 or math.abs(p.Z) > 500000
end

local function generateDeepVoid()
    local positions = {}
    local depths = {-1e6, -2e6, -5e6, -1e7, -2e7}
    local far = {-1e6, -5e5, -2e5, -1e5, 1e5, 2e5, 5e5, 1e6}
    for i = 1, 20 do
        local x = far[math.random(1,#far)] + math.random(-5000,5000)
        local y = depths[math.random(1,#depths)] + math.random(-5000,5000)
        local z = far[math.random(1,#far)] + math.random(-5000,5000)
        positions[i] = CFrame.new(x,y,z)
    end
    return positions
end
local deepVoidPositions = generateDeepVoid()

local function updateSimulation(dt)
    if not VoidFramework.desyncEnabled then return end
    local S = VoidFramework.settings
    local baseVel = Vector3.new(math.random(-S.rand_vel_x, S.rand_vel_x), math.random(-S.rand_vel_y, S.rand_vel_y), math.random(-S.rand_vel_z, S.rand_vel_z))
    local jerkIntensity = S.jerk_intensity / 100
    local randIntensity = S.random_vel_intensity / 100
    VoidFramework.jerkTimer -= dt
    if VoidFramework.jerkTimer <= 0 then
        VoidFramework.jerkTimer = math.random(3,10)/10
        local jerk = Vector3.new(math.random(-40,40) * jerkIntensity, math.random(-40,40) * jerkIntensity, math.random(-40,40) * jerkIntensity)
        VoidFramework.simVelocity = VoidFramework.simVelocity + jerk
    end
    local chaos = Vector3.new(math.random(-60,60) * randIntensity, math.random(-60,60) * randIntensity, math.random(-60,60) * randIntensity)
    VoidFramework.simVelocity = (VoidFramework.simVelocity * 0.9) + baseVel + chaos
    VoidFramework.simPosition = VoidFramework.simPosition + VoidFramework.simVelocity * dt
end

local function getDesyncOffset()
    local S = VoidFramework.settings
    local anchor = Vector3.new(0,0,0)
    if VoidFramework.voidActive and deepVoidPositions[VoidFramework.currentVoidIndex] then
        local baseCF = deepVoidPositions[VoidFramework.currentVoidIndex]
        local depth = S.depthMultiplier or 1
        local bp = baseCF.Position
        anchor = Vector3.new(bp.X * depth, bp.Y * depth, bp.Z * depth)
    end
    return anchor + VoidFramework.simPosition
end

local function getHRP(p) return p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") end
local function getHumanoid(p) return p and p.Character and p.Character:FindFirstChildOfClass("Humanoid") end

local function startCSync()
    local hrp = getHRP(LocalPlayer)
    if not hrp then return end
    if VoidFramework.csyncConnection then return end
    VoidFramework.csyncConnection = RunService.Heartbeat:Connect(function()
        local hrp = getHRP(LocalPlayer)
        if not hrp then return end
        local realCF = hrp.CFrame
        local offset = getDesyncOffset()
        hrp.CFrame = CFrame.new(offset)
        RunService.RenderStepped:Wait()
        hrp.CFrame = realCF
    end)
end

local function stopCSync()
    if VoidFramework.csyncConnection then
        VoidFramework.csyncConnection:Disconnect()
        VoidFramework.csyncConnection = nil
    end
end

local function updateVoid(dt)
    if not VoidFramework.voidActive then return end
    local S = VoidFramework.settings
    if tick() - VoidFramework.lastSwitch < S.switchSpeed then return end
    VoidFramework.lastSwitch = tick()
    VoidFramework.currentVoidIndex = (VoidFramework.currentVoidIndex % #deepVoidPositions) + 1
end

local function startVoid()
    local hrp = getHRP(LocalPlayer)
    if not hrp then return end
    VoidFramework.originalCFrame = hrp.CFrame
    VoidFramework.voidActive = true
    VoidFramework.desyncEnabled = true
    startCSync()
end

local function stopVoid()
    VoidFramework.voidActive = false
    VoidFramework.desyncEnabled = false
    stopCSync()
end

local function safeReturn()
    stopCSync()
    task.wait(0.1)
    local hrp = getHRP(LocalPlayer)
