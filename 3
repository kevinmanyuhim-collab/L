local renderConn = RunService.RenderStepped:Connect(function()
	updateESP()
	updateSkeletonESP()
	updateRadar()
	updateTargetMarker()
	updateThirdPerson()
	updateCrosshair()
	updateFOV()
	updateFullbright()
	updateNoFog()
	updateTime()
	updateGravity()
	updateRemoveClouds()
	updateNoPlants()
	updateAntiAim()
	updateSpeed()
	
	updateNativeChams()
	updateOffScreenIndicators()
	updateTargetHud()
    updateViewModel()
    updateHitSound()
	
	-- ========== Aimbot 與 FOV 邏輯整合更新 ==========
	if FOVCircle then
		FOVCircle.Visible = ExtraToggles.AimbotEnabled and getgenv().ShowFOVCircle
		
		FOVCircle.Color = ExtraToggles.FOVColor
		FOVCircle.Filled = ExtraToggles.FOVFilled
		FOVCircle.Transparency = ExtraToggles.FOVTransparency
		
		if ExtraToggles.AimbotDynamicFOV then
			local fovScale = 70 / Camera.FieldOfView
			FOVCircle.Radius = ExtraToggles.AimbotFOV * fovScale
		else
			FOVCircle.Radius = ExtraToggles.AimbotFOV
		end
		
		if UserInputService.TouchEnabled then
			FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
		else
			FOVCircle.Position = UserInputService:GetMouseLocation()
		end
	end

	-- ========== Silent Aim FOV 邏輯更新 ==========
	if SilentAimFOVCircle then
		SilentAimFOVCircle.Visible = ExtraToggles.ShowSilentAimFOV
		SilentAimFOVCircle.Radius = ExtraToggles.SilentAimFOV
		SilentAimFOVCircle.Color = ExtraToggles.SilentAimFOVColor
		SilentAimFOVCircle.Filled = ExtraToggles.SilentAimFOVFilled
		SilentAimFOVCircle.Transparency = ExtraToggles.SilentAimFOVTransparency
		
		if UserInputService.TouchEnabled then
			SilentAimFOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
		else
			SilentAimFOVCircle.Position = UserInputService:GetMouseLocation()
		end
	end

	if ExtraToggles.AimbotEnabled then
		local shouldAim = false
		if UserInputService.TouchEnabled then
			shouldAim = MobileAiming
		else
			if ExtraToggles.AimbotHoldMode then
				shouldAim = IsAimKeyDown
			else
				shouldAim = AimbotToggled
			end
		end

		if shouldAim then
			local hitChanceValid = true
			if ExtraToggles.AimbotHitChance < 100 then
				hitChanceValid = math.random(1, 100) <= ExtraToggles.AimbotHitChance
			end
			
			if hitChanceValid then
				local target = getAimbotTarget()
				if target and target.Character then
					local partName = ExtraToggles.AimbotPart and "Head" or "HumanoidRootPart"
					local targetPart = target.Character:FindFirstChild(partName)
					if targetPart then
						local targetPos = targetPart.Position
						if ExtraToggles.AimbotPrediction and targetPart.Velocity then
							targetPos = targetPos + (targetPart.Velocity * ExtraToggles.AimbotPredictionStrength)
						end
						
						local cam = workspace.CurrentCamera
						local newCFrame = CFrame.new(cam.CFrame.Position, targetPos)
						
						if ExtraToggles.AimbotSmoothnessValue > 0 and ExtraToggles.AimbotSmoothnessValue < 1 then
							local lerpFactor = 1 - ExtraToggles.AimbotSmoothnessValue
							cam.CFrame = cam.CFrame:Lerp(newCFrame, lerpFactor) 
						else
							cam.CFrame = newCFrame
						end
					end
				end
			end
		end
	end
end)
