			if MobileAimBtnUI then MobileAimBtnUI.Enabled = false end
			MobileAiming = false
		end
	end
end

-- ========== Universal Silent Aim (Hook) ==========
local mt = getrawmetatable(game)
if mt then
	local oldIndex = mt.__index
	setreadonly(mt, false)
	mt.__index = newcclosure(function(t, k)
		if ExtraToggles.SilentAim and not checkcaller() and typeof(t) == "Instance" and t:IsA("Mouse") then
			if k == "Hit" or k == "Target" then
				local target = nil
				local center
				if UserInputService.TouchEnabled then
					center = Vector2.new(workspace.CurrentCamera.ViewportSize.X/2, workspace.CurrentCamera.ViewportSize.Y/2)
				else
					center = UserInputService:GetMouseLocation()
				end
				local minAngle = ExtraToggles.SilentAimFOV
				for _, player in ipairs(Players:GetPlayers()) do
					if player ~= LocalPlayer and player.Character then
						if ExtraToggles.AimbotTeamCheck and player.Team == LocalPlayer.Team then continue end
						local partName = ExtraToggles.SilentAimPart and "Head" or "HumanoidRootPart"
						local part = player.Character:FindFirstChild(partName)
						local hum = player.Character:FindFirstChildOfClass("Humanoid")
						if part and hum and hum.Health > 0 then
							local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
							if onScreen then
								if ExtraToggles.WallCheck and not isVisible(part) then continue end
								local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
								if dist < minAngle then minAngle = dist; target = player end
							end
						end
					end
				end
				if target and target.Character then
					local hitChanceValid = true
					if ExtraToggles.SilentAimHitChance < 100 then
						hitChanceValid = math.random(1, 100) <= ExtraToggles.SilentAimHitChance
					end
					if hitChanceValid then
						local partName = ExtraToggles.SilentAimPart and "Head" or "HumanoidRootPart"
						local targetPart = target.Character:FindFirstChild(partName)
						if targetPart then
							if k == "Hit" then return targetPart.CFrame
							elseif k == "Target" then return targetPart end
						end
					end
				end
			end
		end
		return oldIndex(t, k)
	end)
	setreadonly(mt, true)
end

