local VoidFramework = {
    voidActive = false, lastSwitch = 0, currentVoidIndex = 1, originalCFrame = nil,
    csyncConnection = nil, desyncEnabled = false, simPosition = Vector3.new(0,0,0),
    simVelocity = Vector3.new(0,0,0), jerkTimer = 0,
