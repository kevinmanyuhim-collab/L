local function updateOrbit()
	if not ExtraToggles.OrbitEnabled then
		if ExtraConnections.Orbit then ExtraConnections.Orbit:Disconnect(); ExtraConnections.Orbit = nil end
		return
	end
	if ExtraConnections.Orbit then return end
	ExtraConnections.Orbit = RunService.Heartbeat:Connect(function()
		local target = getClosestPlayer()
		if not target or not target.Character then return end
		local hrp = getHRP(target)
		local myHrp = getHRP(LocalPlayer)
		if not hrp or not myHrp then return end

		local baseDistance = ExtraToggles.OrbitDistance
		local baseSpeed = ExtraToggles.OrbitSpeed
		local distance = baseDistance
		if ExtraToggles.OrbitDynamicRadius then
			OrbitRadiusTime = OrbitRadiusTime + (RunService.Heartbeat:Wait() or 0.016)
			local radiusOffset = math.sin(OrbitRadiusTime * ExtraToggles.OrbitRadiusFrequency * 2 * math.pi) * ExtraToggles.OrbitRadiusAmplitude
			distance = math.max(1, baseDistance + radiusOffset)
		end
		local speed = baseSpeed
		if ExtraToggles.OrbitDynamicSpeed then
			OrbitSpeedTime = OrbitSpeedTime + (RunService.Heartbeat:Wait() or 0.016)
			local speedOffset = math.sin(OrbitSpeedTime * ExtraToggles.OrbitSpeedFrequency * 2 * math.pi) * ExtraToggles.OrbitSpeedAmplitude
			speed = math.max(0.1, baseSpeed + speedOffset)
			speed = math.min(2000, speed)
		end
		local rx = distance; local rz = distance
		if ExtraToggles.OrbitEllipse then
			rx = distance * ExtraToggles.OrbitEllipseXRatio
			rz = distance * ExtraToggles.OrbitEllipseZRatio
		end
		local dt = RunService.Heartbeat:Wait() or 0.016
		OrbitAngle = (OrbitAngle or 0) + math.rad(speed) * dt
		local x = math.cos(OrbitAngle) * rx
		local z = math.sin(OrbitAngle) * rz
		local yOffset = 0
		if ExtraToggles.OrbitHeightMode then
			local time = tick()
			yOffset = math.sin(time * ExtraToggles.OrbitHeightFrequency * 2 * math.pi) * ExtraToggles.OrbitHeightAmplitude
		end
		myHrp.CFrame = CFrame.new(hrp.Position + Vector3.new(x, yOffset, z))
	end)
end

local function updateAntiAim()
	if not ExtraToggles.AntiAim then
		if ExtraConnections.AntiAim then ExtraConnections.AntiAim:Disconnect(); ExtraConnections.AntiAim = nil end
		return
	end
	if ExtraConnections.AntiAim then return end
	ExtraConnections.AntiAim = RunService.RenderStepped:Connect(function()
		local char = LocalPlayer.Character
		if not char then return end
		local root = char:FindFirstChild("HumanoidRootPart")
		if not root then return end
		local now = tick()
		if now - LastAntiAimTime < (1 / ExtraToggles.AntiAimFrequency) then return end
		LastAntiAimTime = now
		local mode = ExtraToggles.AntiAimMode
		local speed = ExtraToggles.AntiAimSpeed
		local radius = ExtraToggles.AntiAimRadius
		local angle = now * speed
		if mode == "FullBody" then root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(angle), 0)
		elseif mode == "Rotate" then root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(angle), math.rad(angle))
		elseif mode == "Shake" then root.CFrame = root.CFrame * CFrame.Angles(math.sin(angle)*radius, math.sin(angle*2)*radius, 0)
		elseif mode == "Jitter" then
			local jitter = Vector3.new(math.sin(angle)*radius, math.cos(angle*1.3)*radius, math.sin(angle*1.7)*radius)
			root.CFrame = root.CFrame * CFrame.Angles(jitter.X, jitter.Y, jitter.Z)
		elseif mode == "Spiral" then root.CFrame = root.CFrame * CFrame.Angles(math.sin(angle)*radius, angle, math.cos(angle)*radius)
		elseif mode == "Figure8" then root.CFrame = root.CFrame * CFrame.Angles(math.sin(angle)*radius, math.sin(angle*2)*radius, 0)
		end
	end)
end

