local function updateHitSound()
    if not ExtraToggles.HitSoundEnabled then return end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local currentHealth = hum.Health
                if EnemyHealths[player] and currentHealth < EnemyHealths[player] then
                    -- 敵人扣血了，播放音效
                    local s = Instance.new("Sound", Workspace)
                    s.SoundId = HitSoundIDs[ExtraToggles.HitSoundType] or HitSoundIDs.Rust
                    s.Volume = ExtraToggles.HitSoundVolume
                    s:Play()
                    Debris:AddItem(s, 2)
                end
                EnemyHealths[player] = currentHealth
            end
        end
    end
end

